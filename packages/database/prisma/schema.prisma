// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// El Negocio (Colmado o Minimarket) — Tenant SaaS
model Tenant {
  id        String   @id @default(uuid())
  name      String
  rnc       String   @unique
  phone     String?
  address   String?
  isActive  Boolean  @default(true)
  plan      String   @default("BASIC")
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  products       Product[]
  sales          Sale[]
  ncfSequences   NCFSequence[]
  cashDrawerLogs CashDrawerLog[]
}

// Usuarios (Super Admin, Administradores de colmado, Cajeros)
model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(CASHIER)
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
}

enum Role {
  SUPER_ADMIN
  ADMIN
  CASHIER
}

// Inventario
model Product {
  id        String     @id @default(uuid())
  barcode   String?
  name      String
  price     Float
  cost      Float
  stock     Int        @default(0)
  category  String?
  tenantId  String
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  saleItems SaleItem[]

  @@unique([barcode, tenantId])
}

// Secuencias de NCF
model NCFSequence {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  type      NcfType
  prefix    String
  nextValue Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, type])
}

// Ventas y Facturación (Adaptado a RD)
model Sale {
  id           String     @id @default(uuid())
  total        Float
  cashReceived Float?
  changeDue    Float?
  ncf          String?
  ncfType      NcfType    @default(CONSUMIDOR_FINAL)
  clientRnc    String?
  itbis        Float      @default(0)
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id])
  createdAt    DateTime   @default(now())
  items        SaleItem[]
}

model SaleItem {
  id        String  @id @default(uuid())
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
  cost      Float
}

// Cierre de Caja (Cash Drawer Audit)
model CashDrawerLog {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  shiftDate    DateTime @default(now())
  expectedCash Float
  countedCash  Float
  discrepancy  Float
  notes        String?
  createdAt    DateTime @default(now())
}

enum NcfType {
  CONSUMIDOR_FINAL
  CREDITO_FISCAL
  GUBERNAMENTAL
}
