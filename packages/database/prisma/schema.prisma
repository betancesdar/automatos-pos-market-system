// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  rnc       String   @unique
  phone     String?
  address   String?
  isActive  Boolean  @default(true)
  plan      String   @default("BASIC")
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  categories     Category[]
  products       Product[]
  sales          Sale[]
  ncfSequences   NCFSequence[]
  cashDrawerLogs CashDrawerLog[]
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(CASHIER)
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
}

enum Role {
  SUPER_ADMIN
  ADMIN
  CASHIER
}

model Category {
  id        String    @id @default(uuid())
  name      String
  slug      String
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  products  Product[]
  createdAt DateTime  @default(now())

  @@unique([slug, tenantId])
}

model Product {
  id         String     @id @default(uuid())
  barcode    String?
  name       String
  price      Float
  cost       Float
  stock      Int        @default(0)
  imageUrl   String?
  categoryId String?
  category   Category?  @relation(fields: [categoryId], references: [id])
  tenantId   String
  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  saleItems  SaleItem[]

  @@unique([barcode, tenantId])
}

model NCFSequence {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  type      NcfType
  prefix    String
  nextValue Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, type])
}

model Sale {
  id            String        @id @default(uuid())
  total         Float
  subtotal      Float         @default(0)
  cashReceived  Float?
  changeDue     Float?
  ncf           String?
  ncfType       NcfType       @default(VENTA_RAPIDA)
  clientRnc     String?
  itbis         Float         @default(0)
  applyItbis    Boolean       @default(false)
  paymentMethod PaymentMethod @default(CASH)
  tenantId      String
  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  createdAt     DateTime      @default(now())
  items         SaleItem[]
}

model SaleItem {
  id        String  @id @default(uuid())
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Float
  price     Float
  cost      Float
  isLoose   Boolean @default(false)
}

model CashDrawerLog {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  shiftDate    DateTime @default(now())
  expectedCash Float
  countedCash  Float
  discrepancy  Float
  notes        String?
  createdAt    DateTime @default(now())
}

enum NcfType {
  SIN_NCF
  VENTA_RAPIDA
  CONSUMIDOR_FINAL
  CREDITO_FISCAL
  REGISTRO_UNICO_INGRESO
  GUBERNAMENTAL
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}
